# Local-only defaults. Production secrets must live outside the repository.
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3020
ADMIN_APP_URL=http://127.0.0.1:5178
STOREFRONT_APP_URL=http://127.0.0.1:5179

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=siemprebarato_dev
DB_USER=siemprebarato_app
DB_PASSWORD=siemprebarato_local_only

BOOTSTRAP_SUPER_ADMIN_EMAIL=camiloefg@gmail.com
AUTH_SESSION_PEPPER=replace-this-local-session-pepper-before-sharing
OAUTH_STATE_SECRET=replace-this-local-oauth-state-secret-before-sharing
ADMIN_SESSION_TTL_HOURS=12

# Create the OAuth client later in the dedicated Siempre Barato GCP project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:3020/api/auth/google/callback

# Safe local UI testing without Google. The API rejects this outside development.
ALLOW_DEV_AUTH_BYPASS=true

MERCADOLIBRE_WORKER_ENABLED=false
MERCADOLIBRE_WORKER_POLL_MS=60000
MERCADOLIBRE_API_BASE_URL=https://api.mercadolibre.com
# Keep OAuth credentials in environment/secret storage only. Never commit real values.
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_ACCESS_TOKEN=
